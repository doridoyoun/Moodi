{
  "expo": {
    "name": "Moodi",
    "slug": "Moodi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EAF1C8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.doyun.moodi",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EAF1C8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Moodi가 사진을 선택할 수 있도록 갤러리 접근을 허용합니다.",
          "cameraPermission": "Moodi가 사진을 촬영할 수 있도록 카메라 접근을 허용합니다."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Moodi가 사진을 저장하기 위해 갤러리에 접근합니다.",
          "savePhotosPermission": "Moodi가 Today's Moodi 이미지를 앨범에 저장합니다.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "045a0ccc-17e1-49b3-974d-87482d298186"
      }
    }
  }
}
